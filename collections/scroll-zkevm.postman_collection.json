  "info": {
    "_postman_id": "b0c38b04-a410-411b-b85d-6c3b79d36a12",
    "name": "Scroll JSON-RPC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Standard Ethereum JSON-RPC interface for the Scroll zkEVM Layer 2. Available on mainnet (chain ID 534352) and Sepolia testnet (chain ID 534351). All methods are exposed as POST requests with a JSON-RPC 2.0 envelope. Scroll is EVM-equivalent; standard eth_*, net_*, web3_* methods work, with rollup-specific opcode notes at rollup.codes/scroll.\n\nContact Support:\n Name: Scroll Foundation",
      "type": "text/plain"
    }
