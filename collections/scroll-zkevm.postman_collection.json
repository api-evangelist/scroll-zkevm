      "item": [
        {
          "id": "df91612b-bdac-4878-bfb8-864408b16a12",
          "name": "Submit a JSON-RPC request",
          "request": {
            "name": "Submit a JSON-RPC request",
            "description": {
              "content": "Submit any standard Ethereum JSON-RPC 2.0 request. The `method` field selects the operation. Common methods include `eth_chainId`, `eth_blockNumber`, `eth_getBalance`, `eth_getTransactionByHash`, `eth_getTransactionReceipt`, `eth_call`, `eth_sendRawTransaction`, `eth_estimateGas`, `eth_getBlockByNumber`, `eth_getLogs`, `net_version`, `web3_clientVersion`.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"<string>\",\n  \"method\": \"<string>\",\n  \"id\": \"<integer>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "d3d8bfef-71b5-401f-b5fa-6adfdef2dbd5",
              "name": "JSON-RPC response",
              "originalRequest": {
